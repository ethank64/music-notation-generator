# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# These are read server-side by the /api/generate function (never exposed to the browser).

# Required for local dev: your Vercel AI Gateway API key (starts with "vck_").
# Get one at https://vercel.com/dashboard → AI Gateway → API Keys.
# When DEPLOYED on Vercel this is optional — the function authenticates to the
# gateway via OIDC automatically.
AI_GATEWAY_API_KEY=vck_...

# Optional: which model to route through the gateway, as "provider/model".
# Defaults to openai/gpt-4o-mini. Switching vendors is just changing this:
#   anthropic/claude-sonnet-4.6, google/gemini-2.5-flash, xai/grok-4, etc.
# NOTATION_MODEL=openai/gpt-4o-mini

# Frontend flag (VITE_ prefix = exposed to the browser). Set to "false" to call
# the real /api/generate backend instead of the in-browser mock. Defaults to
# mock so `npm run dev` works offline with no key.
VITE_USE_MOCK=true
