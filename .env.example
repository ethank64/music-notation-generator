# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# These are read server-side by the /api/generate function (never exposed to the browser).

# Required: your OpenAI API key (or a key for any OpenAI-compatible provider).
OPENAI_API_KEY=sk-...

# Optional: which chat model to use. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional: point at any OpenAI-compatible endpoint (vLLM, TGI, Together, a
# self-hosted fine-tuned model). Leave unset to use OpenAI's API.
# OPENAI_BASE_URL=https://your-endpoint/v1

# Frontend flag (VITE_ prefix = exposed to the browser). Set to "false" to call
# the real /api/generate backend instead of the in-browser mock. Defaults to
# mock so `npm run dev` works offline with no key.
VITE_USE_MOCK=true
